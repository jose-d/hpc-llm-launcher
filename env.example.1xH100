# Runtime overrides for scripts/sbatch-vllm-serve.sh

# Repo-local workdir. If you put a vLLM environment in this repo, leave this as .
VLLM_WORKDIR=.

# If you have a local environment inside the repo, this is the usual path.
VLLM_EXEC=./.venv/bin/vllm

# Module settings used by the startup hook below.
GCC_MODULE_NAME=GCC/.14.2.0
CUDA_MODULE_NAME=CUDA/12.9.1

VLLM_STARTUP_CMD="module load ${GCC_MODULE_NAME} ${CUDA_MODULE_NAME}"

# Set the model you want to serve.
MODEL_ID=Qwen/Qwen3-30B-A3B-Thinking-2507

# Optional auth and Hugging Face overrides.
# OPENAI_API_KEY=change-me
# OPENAI_API_KEY_FILE=./.api-key
# HF_TOKEN=...

# 1x H100 profile.
PORT=8000
TUNNEL_LOGIN_HOST=machine.test.tld
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.92
# Set explicitly for stable single-GPU startup.
MAX_MODEL_LEN=131072
MAX_NUM_BATCHED_TOKENS=1024
SWAP_SPACE_GB=0
VLLM_HOST=0.0.0.0
ENABLE_AUTO_TOOL_CHOICE=1
TOOL_CALL_PARSER=qwen3_xml
REASONING_PARSER=qwen3

PYTHON_BIN='/usr/bin/python3.12'
