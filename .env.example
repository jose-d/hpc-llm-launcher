# Runtime overrides for scripts/sbatch-vllm-serve.sh

# Repo-local workdir. If you put a vLLM environment in this repo, leave this as .
VLLM_WORKDIR=.

# If you have a local environment inside the repo, this is the usual path.
VLLM_EXEC=./.venv/bin/vllm

# Set the model you want to serve.
MODEL_ID=Qwen/Qwen3-30B-A3B-Thinking-2507

# Startup hook. Leave empty if you are using a prebuilt environment.
# VLLM_STARTUP_CMD=./setup-env.sh

# Optional auth and Hugging Face overrides.
# OPENAI_API_KEY=change-me
# OPENAI_API_KEY_FILE=./.api-key
# HF_TOKEN=...

# Conservative single-GPU defaults.
PORT=8000
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=8192
MAX_NUM_BATCHED_TOKENS=1024
SWAP_SPACE_GB=0
VLLM_HOST=0.0.0.0
